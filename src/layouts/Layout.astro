---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: string;
  transparentNav?: boolean;
}

const { title, description, ogImage = 'https://admin.edgewaterhotel.com/content/uploads/2025/12/The-Edgewater-Hotel-Seattle-WA-1.jpg', schema, transparentNav = false } = Astro.props;
const currentPath = Astro.url.pathname;

// Noble House properties organised by state/region
const nobleHouseByRegion = [
  {
    region: 'California',
    properties: [
      { name: "L'Auberge Del Mar", url: 'https://www.laubergedelmar.com' },
      { name: 'Estancia La Jolla', url: 'https://www.estancialajolla.com' },
      { name: 'Mission Bay Resort', url: 'https://www.missionbayresort.com' },
      { name: 'Resort Kona Kai', url: 'https://www.resortkonakai.com' },
      { name: 'Napa Valley Wine Train', url: 'https://www.winetrain.com' },
    ],
  },
  {
    region: 'Colorado',
    properties: [
      { name: 'Gateway Canyons', url: 'https://www.gatewaycanyons.com' },
    ],
  },
  {
    region: 'Florida',
    properties: [
      { name: 'Little Palm Island', url: 'https://www.littlepalmisland.com' },
      { name: 'Marquesa Hotel', url: 'https://www.marquesa.com' },
      { name: 'Ocean Key Resort', url: 'https://www.oceankey.com' },
      { name: 'Pelican Beach Resort', url: 'https://www.pelicanbeach.com' },
      { name: 'Solé Miami', url: 'https://www.solemiami.com' },
      { name: 'Hotel Portofino', url: 'https://www.hotelportofino.com' },
    ],
  },
  {
    region: 'Georgia',
    properties: [
      { name: 'Jekyll Island Club', url: 'https://www.jekyllclub.com' },
    ],
  },
  {
    region: 'Massachusetts',
    properties: [
      { name: 'Chatham Inn', url: 'https://www.chathaminn.com' },
    ],
  },
  {
    region: 'Mexico',
    properties: [
      { name: 'Corazón Cabo', url: 'https://www.corazoncabo.com' },
    ],
  },
  {
    region: 'Oregon',
    properties: [
      { name: 'Headlands Lodge', url: 'https://www.headlandslodge.com' },
      { name: 'Inn at Cape Kiwanda', url: 'https://www.innatcapekiwanda.com' },
    ],
  },
  {
    region: 'Texas',
    properties: [
      { name: 'The Stella Hotel', url: 'https://www.thestellahotel.com' },
    ],
  },
  {
    region: 'Washington',
    properties: [
      { name: 'Argonaut Hotel', url: 'https://www.argonauthotel.com' },
      { name: 'River Terrace Inn', url: 'https://www.riverterraceinn.com' },
    ],
  },
  {
    region: 'Wyoming',
    properties: [
      { name: "Hart's Camp", url: 'https://www.hartscamp.com' },
      { name: 'Hotel Terra', url: 'https://www.hotelterrajacksonhole.com' },
      { name: 'Snake River Sporting Club', url: 'https://www.snakeriversportingclub.com' },
      { name: 'Teton Lodge', url: 'https://www.tetonlodge.com' },
    ],
  },
  {
    region: 'Naples, FL',
    properties: [
      { name: 'Inn on Fifth', url: 'https://www.innonfifth.com' },
      { name: 'LaPlaya Resort', url: 'https://www.laplayaresort.com' },
    ],
  },
];

const hotelSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Hotel",
  "name": "The Edgewater Hotel",
  "url": "https://www.edgewaterhotel.com",
  "image": ogImage,
  "description": "Seattle's only over-water hotel, an iconic downtown luxury Seattle hotel immortalized in rock history by The Beatles.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2411 Alaskan Way, Pier 67",
    "addressLocality": "Seattle",
    "addressRegion": "WA",
    "postalCode": "98121",
    "addressCountry": "US"
  },
  "telephone": "+1-206-728-7000",
  "email": "info@edgewaterhotel.com",
  "starRating": { "@type": "Rating", "ratingValue": "4" },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Over-Water Rooms", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Waterfront Restaurant", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Coffee Shop", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true }
  ],
  "parentOrganization": {
    "@type": "Organization",
    "name": "Noble House Hotels & Resorts",
    "url": "https://www.noblehousehotels.com"
  }
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Edgewater Hotel Seattle" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="https://www.edgewaterhotel.com/_next/static/media/favicon.6571601d.png" />

  <!-- Cormorant Display (heading serif — dev substitute for Meno Display/Typekit hbk5hzc) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Display:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap" />

  <!-- Hotel Schema -->
  <script type="application/ld+json" set:html={hotelSchema} />

  <!-- Page-specific schema -->
  {schema && <script type="application/ld+json" set:html={schema} />}

  <!-- GTM -->
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TSK3HFH');
  </script>
</head>
<body>
  <!-- GTM noscript -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TSK3HFH" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- Mobile Nav Toggle (CSS-only) -->
  <input type="checkbox" id="mobile-nav-toggle" class="mobile-nav-checkbox" aria-hidden="true" />

  <!-- ============================================================
       HEADER — 2-row structure matching edgewaterhotel.com
       Row 1 (top bar): secondary nav | wordmark | Reserve
       Row 2 (main nav): Stay | Dine | Explore | Gather | Offers
       ============================================================ -->
  <header class:list={['site-nav', { 'nav-transparent': transparentNav, 'nav-solid': !transparentNav }]}>

    <!-- Top bar -->
    <div class="nav-top-bar">
      <div class="nav-top-inner">

        <!-- Secondary nav (left) -->
        <nav class="nav-secondary" aria-label="Secondary navigation">
          <a href="/about/">About</a>
          <a href="/gallery/">Gallery</a>
          <a href="/property-map/">Property Map</a>
        </nav>

        <!-- Wordmark (center) -->
        <a href="/" class="nav-wordmark" aria-label="The Edgewater Hotel — Home">
          <span class="wordmark-name">The Edgewater</span>
          <span class="wordmark-sub">a noble house hotel</span>
        </a>

        <!-- Reserve + hamburger (right) -->
        <div class="nav-top-actions">
          <a
            href="https://www.edgewaterhotel.com/#/booking/step-1"
            class="nav-reserve-btn"
            target="_blank"
            rel="noopener"
          >Reserve</a>
          <label for="mobile-nav-toggle" class="hamburger" aria-label="Open menu">
            <span></span>
            <span></span>
            <span></span>
          </label>
        </div>

      </div>
    </div>

    <!-- Main nav row -->
    <div class="nav-main-row">
      <nav class="nav-primary" aria-label="Main navigation">
        <a href="/stay/" class:list={[{ active: currentPath.startsWith('/stay') }]}>Stay</a>
        <a href="/dine/" class:list={[{ active: currentPath.startsWith('/dine') }]}>Dine</a>
        <a href="/explore/" class:list={[{ active: currentPath.startsWith('/explore') }]}>Explore</a>
        <a href="/gather/" class:list={[{ active: currentPath.startsWith('/gather') }]}>Gather</a>
        <a href="/offers/" class:list={[{ active: currentPath.startsWith('/offers') }]}>Offers</a>
      </nav>
    </div>

  </header>

  <!-- Mobile Nav Drawer -->
  <div class="mobile-nav-drawer">
    <div class="mobile-nav-header">
      <div class="mobile-wordmark">
        <span class="wordmark-name">The Edgewater</span>
        <span class="wordmark-sub">a noble house hotel</span>
      </div>
      <label for="mobile-nav-toggle" class="mobile-nav-close" aria-label="Close menu">&times;</label>
    </div>
    <nav class="mobile-nav-links">
      <a href="/stay/">Stay</a>
      <a href="/dine/">Dine</a>
      <a href="/explore/">Explore</a>
      <a href="/gather/">Gather</a>
      <a href="/offers/">Offers</a>
      <a href="/about/">About</a>
      <a href="/gallery/">Gallery</a>
      <a href="/property-map/">Property Map</a>
    </nav>
    <div class="mobile-nav-footer">
      <a href="tel:206.728.7000" class="mobile-nav-phone">206.728.7000</a>
      <a
        href="https://www.edgewaterhotel.com/#/booking/step-1"
        class="mobile-nav-reserve"
        target="_blank"
        rel="noopener"
      >Reserve</a>
    </div>
  </div>
  <label for="mobile-nav-toggle" class="mobile-nav-backdrop"></label>

  <main>
    <slot />
  </main>

  <!-- Noble House Portfolio — by state/region -->
  <section class="noble-house-section">
    <div class="noble-house-inner">
      <a href="https://www.noblehousehotels.com" class="noble-house-brand" target="_blank" rel="noopener">
        Noble House Hotels &amp; Resorts
      </a>
      <div class="noble-house-grid">
        {nobleHouseByRegion.map(group => (
          <div class="noble-region">
            <span class="noble-region-label">{group.region}</span>
            <ul>
              {group.properties.map(p => (
                <li><a href={p.url} target="_blank" rel="noopener">{p.name}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">

      <!-- Top: logo + address | nav columns | social -->
      <div class="footer-top">

        <!-- Left: logo + address + phones -->
        <div class="footer-address-col">
          <a href="/" class="footer-logo-link" aria-label="The Edgewater Hotel">
            <img
              src="https://admin.edgewaterhotel.com/content/uploads/2026/01/20160718_TE_logo_white-287x66.png"
              alt="The Edgewater Hotel"
              class="footer-logo"
              width="200"
              height="46"
            />
          </a>
          <address class="footer-address">
            <p>2411 Alaskan Way, Pier 67</p>
            <p>Seattle, WA 98121</p>
            <p><a href="tel:2067287000">206.728.7000</a></p>
            <p><a href="tel:8888904525">888.890.4525</a></p>
          </address>
          <div class="footer-social">
            <a href="https://www.facebook.com/edgewaterhotel" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
            <a href="https://www.instagram.com/edgewaterhotel" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          </div>
        </div>

        <!-- Center: Stay + Dine nav -->
        <div class="footer-nav-col">
          <h4>Stay</h4>
          <ul>
            <li><a href="/stay/">Rooms &amp; Suites</a></li>
            <li><a href="/stay/beatles-suite/">Beatles Suite</a></li>
            <li><a href="/stay/pearl-jam-suite/">Pearl Jam Suite</a></li>
            <li><a href="/offers/">Offers &amp; Packages</a></li>
            <li><a href="/stay/amenities/">Amenities</a></li>
          </ul>
        </div>

        <div class="footer-nav-col">
          <h4>Dine</h4>
          <ul>
            <li><a href="/dine/six-seven-restaurant/">Six Seven Restaurant</a></li>
            <li><a href="/dine/the-brim/">The Brim</a></li>
            <li><a href="/dine/lobby-bar/">Lobby Bar</a></li>
            <li><a href="/dine/six-seven-restaurant/#menus">Menus</a></li>
            <li><a href="/dine/six-seven-restaurant/#reservations">Reservations</a></li>
          </ul>
        </div>

        <!-- Right: Explore + Gather + About nav -->
        <div class="footer-nav-col">
          <h4>Explore</h4>
          <ul>
            <li><a href="/explore/">Things To Do</a></li>
            <li><a href="/explore/pike-place-market/">Pike Place Market</a></li>
            <li><a href="/explore/space-needle/">Space Needle</a></li>
            <li><a href="/explore/getting-here/">Getting Here</a></li>
          </ul>
        </div>

        <div class="footer-nav-col">
          <h4>Gather</h4>
          <ul>
            <li><a href="/gather/">Meetings &amp; Events</a></li>
            <li><a href="/gather/weddings/">Weddings</a></li>
            <li><a href="/gather/catering/">Catering</a></li>
          </ul>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} The Edgewater Hotel. A Noble House Hotel. All rights reserved.</p>
        <div class="footer-legal">
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms/">Terms of Use</a>
          <a href="/accessibility/">Accessibility</a>
        </div>
      </div>

    </div>
  </footer>

  <!-- Scroll-aware nav -->
  <script is:inline define:vars={{ transparentNav }}>
    (function() {
      if (!transparentNav) return;
      var nav = document.querySelector('.site-nav');
      var threshold = 60;
      function onScroll() {
        if (window.scrollY > threshold) {
          nav.classList.remove('nav-transparent');
          nav.classList.add('nav-solid');
        } else {
          nav.classList.add('nav-transparent');
          nav.classList.remove('nav-solid');
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>

  <!-- AZDS Booking Engine -->
  <script is:inline src="https://newbooking.azds.com/inline.bundle.js" defer></script>
  <script is:inline src="https://newbooking.azds.com/loader.bundle.js" defer></script>

  <!-- Flip.to Discovery -->
  <script is:inline src="https://cdn.flip.to/public/ftsa2.js" defer></script>
  <script is:inline src="https://components.flip.to/discovery/edgewaterhotel/bundle?lang=en" defer></script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ============================================================
     HEADER
     ============================================================ */
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background-color 0.4s ease, box-shadow 0.4s ease;
  }

  .site-nav.nav-transparent {
    background: transparent;
  }

  .site-nav.nav-solid {
    background: var(--sand-dark);
    box-shadow: 0 1px 8px rgba(0,0,0,0.1);
  }

  /* --- Top bar --- */
  .nav-top-bar {
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .nav-solid .nav-top-bar {
    border-bottom-color: rgba(26,26,25,0.12);
  }

  .nav-top-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Secondary nav (About / Gallery / Property Map) */
  .nav-secondary {
    display: flex;
    gap: var(--space-md);
  }
  .nav-secondary a {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.8);
    transition: color 0.3s;
  }
  .nav-secondary a:hover { color: var(--white); }
  .nav-solid .nav-secondary a { color: rgba(26,26,25,0.65); }
  .nav-solid .nav-secondary a:hover { color: var(--charcoal); }

  /* Wordmark (centre) */
  .nav-wordmark {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    line-height: 1;
    text-decoration: none;
    gap: 3px;
  }
  .wordmark-name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
    transition: color 0.4s;
  }
  .wordmark-sub {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    color: rgba(255,255,255,0.65);
    transition: color 0.4s;
  }
  .nav-solid .wordmark-name { color: var(--charcoal); }
  .nav-solid .wordmark-sub { color: var(--warm-gray); }

  /* Reserve button (top bar) */
  .nav-top-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .nav-reserve-btn {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    padding: 0.45rem 1.2rem;
    border: 1px solid rgba(255,255,255,0.5);
    transition: all 0.25s ease-in-out;
    white-space: nowrap;
  }
  .nav-reserve-btn:hover {
    background: rgba(255,255,255,0.15);
    color: var(--white);
    border-color: rgba(255,255,255,0.8);
  }
  .nav-solid .nav-reserve-btn {
    color: var(--charcoal);
    border-color: var(--charcoal);
  }
  .nav-solid .nav-reserve-btn:hover {
    background: var(--charcoal);
    color: var(--white);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: rgba(255,255,255,0.9);
    transition: all 0.3s ease;
  }
  .nav-solid .hamburger span { background: var(--charcoal); }

  /* --- Main nav row --- */
  .nav-main-row {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-primary {
    display: flex;
    gap: var(--space-2xl);
  }

  .nav-primary a {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.9);
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.3s, border-color 0.2s;
  }
  .nav-primary a:hover,
  .nav-primary a.active {
    color: var(--white);
    border-bottom-color: rgba(255,255,255,0.6);
  }
  .nav-solid .nav-primary a { color: var(--charcoal); }
  .nav-solid .nav-primary a:hover,
  .nav-solid .nav-primary a.active {
    border-bottom-color: var(--charcoal);
  }

  /* ============================================================
     MOBILE NAV
     ============================================================ */
  .mobile-nav-checkbox { display: none; }

  .mobile-nav-drawer {
    position: fixed;
    top: 0;
    right: -100%;
    width: min(360px, 90vw);
    height: 100vh;
    background: var(--white);
    z-index: 200;
    transition: right 0.35s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 30px rgba(0,0,0,0.12);
  }

  .mobile-nav-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .mobile-nav-checkbox:checked ~ .mobile-nav-drawer { right: 0; }
  .mobile-nav-checkbox:checked ~ .mobile-nav-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem var(--space-md);
    border-bottom: 1px solid var(--sand-dark);
  }

  .mobile-wordmark {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mobile-wordmark .wordmark-name {
    color: var(--charcoal);
    font-size: 15px;
  }
  .mobile-wordmark .wordmark-sub {
    color: var(--warm-gray);
    font-size: 10px;
  }

  .mobile-nav-close {
    font-size: 1.8rem;
    cursor: pointer;
    color: var(--charcoal);
    line-height: 1;
    padding: 0.25rem;
  }

  .mobile-nav-links {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  }
  .mobile-nav-links a {
    padding: 0.85rem 0;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.03em;
    border-bottom: 1px solid var(--cream);
    color: var(--charcoal);
  }

  .mobile-nav-footer {
    padding: var(--space-md);
    border-top: 1px solid var(--sand-dark);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .mobile-nav-phone {
    text-align: center;
