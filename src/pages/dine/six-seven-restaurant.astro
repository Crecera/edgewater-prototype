---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="The Six Seven | Fine Dining Seafood Restaurant in Seattle"
  description="The Six Seven waterfront restaurant offers seasonally inspired cuisine crafted with only the freshest and finest organic and naturally raised ingredients."
  ogImage="https://admin.edgewaterhotel.com/content/uploads/2026/02/EdgewaterJune2024-1490.jpg"
>

  <!-- Page Header -->
  <section class="page-header">
    <div class="hero-bg">
      <img
        src="https://admin.edgewaterhotel.com/content/uploads/2026/02/EdgewaterJune2024-1490.jpg"
        alt="Guests having drinks at the bar at Edgewater"
        loading="eager"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <a href="/dine/" class="breadcrumb">&larr; All Dining</a>
      <h1>Six Seven Restaurant</h1>
      <p>A premier waterfront dining destination in Seattle specializing in Pacific Northwest cuisine. Overlooking Elliott Bay, we offer seasonally inspired dishes crafted with fresh, organic, locally sourced ingredients.</p>
    </div>
  </section>

  <!-- Hours & Contact -->
  <section class="section section-sand">
    <div class="container">
      <div class="hours-contact-grid">
        <div>
          <h2 style="margin-bottom: var(--space-md);">Hours & Reservations</h2>
          <div class="hours-grid">
            <div class="hours-item">
              <h4>Brunch</h4>
              <p>Sat & Sun<br/>7:00am – 2:00pm</p>
            </div>
            <div class="hours-item">
              <h4>Dinner</h4>
              <p>Sun – Thurs: 5:30pm – 9:00pm<br/>Fri & Sat: 5:30pm – 9:30pm</p>
            </div>
            <div class="hours-item">
              <h4>Lounge</h4>
              <p>Mon – Fri: 3:00pm – 11:00pm<br/>Sat & Sun: 11:00am – 11:00pm</p>
            </div>
          </div>
        </div>
        <div class="contact-box">
          <h3>Contact</h3>
          <p><a href="tel:2062694575">206.269.4575</a></p>
          <p><a href="mailto:dining@edgewaterhotel.com">dining@edgewaterhotel.com</a></p>
          <a href="#" class="btn btn-primary" style="margin-top: var(--space-sm);">Book A Table</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Highlights -->
  <section class="section">
    <div class="container">
      <span class="label" style="color: var(--warm-gray);">In-Room Dining Menu</span>
      <h2 style="margin-top: 0.5rem; margin-bottom: var(--space-lg);">Menu Highlights</h2>

      <div class="menu-columns">
        <!-- Light Fare -->
        <div class="menu-section">
          <h3>Light Fare</h3>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Yogurt Parfait</div>
              <div class="menu-item-desc">house-made granola, berries</div>
            </div>
            <div class="menu-item-price">$16</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Bagel & Cream Cheese</div>
              <div class="menu-item-desc">plain or everything — make it lox +$4</div>
            </div>
            <div class="menu-item-price">$11</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Warm Steel Cut Oats</div>
              <div class="menu-item-desc">brown sugar, berries, sliced almonds</div>
            </div>
            <div class="menu-item-price">$16</div>
          </div>
        </div>

        <!-- Eggs & Such -->
        <div class="menu-section">
          <h3>Eggs & Such</h3>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Lodge Breakfast</div>
              <div class="menu-item-desc">two eggs, breakfast meat, toast</div>
            </div>
            <div class="menu-item-price">$24</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Breakfast Burrito</div>
              <div class="menu-item-desc">scrambled eggs, ground chorizo, chipotle aioli, pico de gallo, flour tortilla</div>
            </div>
            <div class="menu-item-price">$24</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Steak & Eggs</div>
              <div class="menu-item-desc">two eggs, grilled sirloin steak, toast, chimichurri</div>
            </div>
            <div class="menu-item-price">$39</div>
          </div>
        </div>

        <!-- Handhelds -->
        <div class="menu-section">
          <h3>Handhelds</h3>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Six Seven Burger</div>
              <div class="menu-item-desc">grass-fed beef, aged cheddar, chili remoulade, tomato jam, bread & butter pickles</div>
            </div>
            <div class="menu-item-price">$29</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Korean Chicken Sandwich</div>
              <div class="menu-item-desc">grilled gochujang spiced chicken, mayo, gherkins, cucumber slaw</div>
            </div>
            <div class="menu-item-price">$26</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Fish & Chips</div>
              <div class="menu-item-desc">beer-battered cod, tartar sauce</div>
            </div>
            <div class="menu-item-price">$32</div>
          </div>
        </div>

        <!-- Soup & Salad -->
        <div class="menu-section">
          <h3>Soup & Salad</h3>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Six Seven Clam Chowder</div>
              <div class="menu-item-desc">bacon, celery, potatoes</div>
            </div>
            <div class="menu-item-price">$15</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">PNW Cobb</div>
              <div class="menu-item-desc">shrimp, crab, salmon, mixed greens, egg, avocado, bacon, thousand island</div>
            </div>
            <div class="menu-item-price">$32</div>
          </div>
          <div class="menu-item">
            <div>
              <div class="menu-item-name">Caesar</div>
              <div class="menu-item-desc">romaine, parmesan reggiano, croutons</div>
            </div>
            <div class="menu-item-price">$17</div>
          </div>
        </div>
      </div>

      <p class="menu-note">* Consuming raw or uncooked meats, poultry, seafood, shellfish or eggs may increase your risk of foodborne illness. ** Contains Nuts</p>
    </div>
  </section>

  <!-- Additional Dining -->
  <section class="section section-cream">
    <div class="container">
      <h2 style="margin-bottom: var(--space-lg);">Additional Dining At The Edge</h2>
      <div class="grid-3">
        <div class="card">
          <img
            class="card-img"
            src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edgewater_April2024-5774-1.jpg"
            alt="A hot beverage and a book on Kurt Cobain at Brim"
            loading="lazy"
          />
          <div class="card-body">
            <h3>The Brim Coffee Shop</h3>
            <p>Classic coffees and teas with seasonal drink menus, plus grab-and-go snacks and a curated selection of local, unique gifts.</p>
            <a href="#" class="btn btn-outline btn-sm">View Details</a>
          </div>
        </div>

        <div class="card">
          <img
            class="card-img"
            src="https://admin.edgewaterhotel.com/content/uploads/2026/01/EdgeXmasBar2025-1719-cropped-scaled.jpg"
            alt="Cocktails at the Lobby bar"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Lobby Bar</h3>
            <p>This seasonally available pop-up bar experience features curated cocktails, seasonal bites and a charming atmosphere.</p>
            <a href="#" class="btn btn-outline btn-sm">View Details</a>
          </div>
        </div>

        <div class="card">
          <img
            class="card-img"
            src="https://admin.edgewaterhotel.com/content/uploads/2026/01/nhh200-noble-house-edgewater-dining-3.jpg"
            alt="Sunset lit dining room on the water"
            loading="lazy"
          />
          <div class="card-body">
            <h3>Private Dining</h3>
            <p>Celebrate special moments at Six Seven where stunning views meet award-winning cuisine. From buyouts to small gatherings.</p>
            <a href="mailto:edgesales@edgewaterhotel.com" class="btn btn-outline btn-sm">Inquire Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: var(--space-md);">Gallery</h2>
    </div>
    <div class="gallery-strip">
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edge_Nov2024-6937.jpg" alt="Bar with stone fireplace" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edgewater_May2024-9450.jpg" alt="Guests eating overlooking the water" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/02/DSC04541.jpg" alt="Margaritas at Six Seven" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Asparagus-Fries-Fries-Tuna-Tacos-Aperol-Spritz-Barrel-Aged-Old-Fashioned-Aviation.jpg" alt="Food and cocktails" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edgewater_June2025-5649-1.jpg" alt="Dishes and beverages" loading="lazy" />
    </div>
  </section>

</Layout>

<style>
  .breadcrumb {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }
  .breadcrumb:hover { color: #fff; }

  .hours-contact-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-xl);
    align-items: start;
  }

  .contact-box {
    background: var(--white);
    padding: var(--space-md);
  }

  .contact-box h3 {
    margin-bottom: var(--space-sm);
  }

  .contact-box p {
    font-size: 0.95rem;
    margin-bottom: 0.3rem;
  }

  .contact-box a {
    color: var(--charcoal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .menu-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .menu-note {
    margin-top: var(--space-lg);
    font-size: 0.8rem;
    color: var(--warm-gray);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .hours-contact-grid {
      grid-template-columns: 1fr;
    }
    .menu-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
