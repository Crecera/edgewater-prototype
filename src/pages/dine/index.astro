---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Dining at the Edgewater Hotel | Waterfront Dining in Seattle"
  description="Savor Pacific Northwest flavors with stunning waterfront views at The Edgewater Hotel. Enjoy brunch or dinner, fresh-brewed coffee, or a handcrafted cocktail."
  ogImage="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edge_Nov2024-6884.jpg"
>

  <!-- Page Header -->
  <section class="page-header">
    <div class="hero-bg">
      <img
        src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edge_Nov2024-6884.jpg"
        alt="An empty dining area at the Edgewater bar before service"
        loading="eager"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>Over-Water Dining in Seattle</h1>
      <p>Savor Pacific Northwest flavors with stunning waterfront views at The Edgewater Hotel. Located on Elliott Bay, our iconic waterfront hotel offers brunch and dinner featuring fresh, locally sourced ingredients.</p>
    </div>
  </section>

  <!-- Six Seven -->
  <section class="feature-split">
    <img
      class="feature-split-img"
      src="https://admin.edgewaterhotel.com/content/uploads/2026/02/EdgewaterJune2024-1597.jpg"
      alt="A man and a woman looking out to the water on the patio"
      loading="lazy"
    />
    <div class="feature-split-content">
      <span class="label">Signature Restaurant</span>
      <h2>Six Seven Restaurant</h2>
      <p>The award-winning Six Seven Restaurant showcases seasonally inspired cuisine made with the freshest organic ingredients, delivering an unforgettable waterfront dining experience in Seattle.</p>
      <div class="split-actions">
        <a href="/dine/six-seven-restaurant/" class="btn btn-primary">View Details</a>
        <a href="#" class="btn btn-outline">Make A Reservation</a>
      </div>
    </div>
  </section>

  <!-- The Brim -->
  <section class="feature-split reverse">
    <img
      class="feature-split-img"
      src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edgewater_April2024-5853.jpg"
      alt="A fresh pastry and hot beverage on a live edge wood table"
      loading="lazy"
    />
    <div class="feature-split-content section-cream">
      <span class="label">Coffee & Gifts</span>
      <h2>The Brim Coffee Shop</h2>
      <p>Wake up with The Brim, Seattle's only over-water coffee shop, offering fresh coffee, seasonal sips and easy grab-and-go goodies for the day. Discover one-of-a-kind souvenirs, or come back later for curated cocktails and wines.</p>
      <a href="#" class="btn btn-outline">Learn More</a>
    </div>
  </section>

  <!-- Lobby Bar -->
  <section class="feature-split">
    <img
      class="feature-split-img"
      src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edge_AutumnBarFB2025-6431-1.jpg"
      alt="A spread of cured meats, fries, and cocktails"
      loading="lazy"
    />
    <div class="feature-split-content">
      <span class="label">Seasonal Pop-Up</span>
      <h2>Lobby Bar</h2>
      <p>This seasonally available pop-up bar experience features curated cocktails, seasonal bites and a charming atmosphere. Stay tuned to find out more about what we're planning next.</p>
      <a href="#" class="btn btn-outline">Learn More</a>
    </div>
  </section>

  <!-- In-Room Dining -->
  <section class="feature-split reverse">
    <img
      class="feature-split-img"
      src="https://admin.edgewaterhotel.com/content/uploads/2026/02/Edgewater_Aug2025-2332-cropped-1.jpg"
      alt="A guest enjoying a cocktail and food in their room"
      loading="lazy"
    />
    <div class="feature-split-content section-sand">
      <span class="label">Room Service</span>
      <h2>In-Room Dining</h2>
      <p>From a leisurely breakfast in bed to romantic dinners on the balcony, our in-room dining menu has the perfect flavors for every occasion and every palate.</p>
      <a href="#" class="btn btn-outline">View Menu</a>
    </div>
  </section>

</Layout>

<style>
  .split-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
</style>
