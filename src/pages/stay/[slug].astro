---
import Layout from '../../layouts/Layout.astro';
import { getRooms, getRoom } from '../../lib/payload';

export async function getStaticPaths() {
  try {
    const rooms = await getRooms();
    return rooms.map((room: any) => ({
      params: { slug: room.slug },
      props: { room },
    }));
  } catch {
    // Fallback: if Payload is not running, generate the Beatles Suite page
    return [{
      params: { slug: 'beatles-suite' },
      props: { room: null },
    }];
  }
}

const { room } = Astro.props;

// Fallback data if Payload is not available
const name = room?.name || 'Beatles Suite';
const slug = room?.slug || 'beatles-suite';
const category = room?.category || 'specialty';
const sqft = room?.squareFeet || 750;
const sleeps = room?.sleeps || 2;
const shortDesc = room?.shortDescription || 'Relive a legendary moment in history and stay in the suite made famous by the iconic image of The Beatles fishing out of the window.';
const amenities = room?.amenities || [
  { name: 'Gas fireplace' },
  { name: '50" Television & streaming entertainment' },
  { name: 'Keurig coffee machine' },
  { name: 'Refrigerator & Honor Bar' },
  { name: 'Laptop-compatible in-room safe' },
  { name: 'Down feather comforter' },
  { name: 'In-room Wi-Fi' },
  { name: 'Glass surround shower with waterfall & handheld heads' },
  { name: 'Panoramic views of Elliott Bay' },
  { name: 'State-of-the-art stereo with Beatles CD collection' },
  { name: 'Living room, dining area and library' },
];
const tourUrl = room?.tourUrl || 'https://visitingmedia.com/tt8/?ttid=the-edgewater-hotel-icms/';
---

<Layout
  title={`${name} | The Edgewater Hotel Seattle`}
  description={shortDesc}
  ogImage="https://admin.edgewaterhotel.com/content/uploads/2026/01/nhh200-noble-house-edgewater-stay-beatles-3.jpg"
  transparentNav={true}
>

  <!-- Page Header -->
  <section class="page-header room-hero">
    <div class="hero-bg">
      <img
        src="https://admin.edgewaterhotel.com/content/uploads/2025/12/b2-scaled.jpg"
        alt={name}
        loading="eager"
      />
    </div>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <a href="/stay/" class="breadcrumb">&larr; All Rooms</a>
      <h1>{name}</h1>
      <div class="room-meta" style="margin-top: var(--space-sm);">
        <span>{category === 'over-water' ? 'Over-Water' : category === 'city-view' ? 'City View' : 'Specialty'}</span>
        <span>Sleeps {sleeps}</span>
        <span>{sqft} sq ft</span>
      </div>
    </div>
  </section>

  <!-- Room Description -->
  <section class="section">
    <div class="container room-content-grid">
      <div class="room-description">
        <p class="lead">{shortDesc}</p>
        <p>Full panoramic views of Elliott Bay create a striking backdrop, while the plush king bed ensures a restful and comfortable stay. The studio-style living room offers generous space with its library, dining area and gas fireplace, creating a welcoming setting for relaxation or entertaining.</p>
        <p>Music lovers will appreciate the state-of-the-art stereo system paired with a curated Beatles CD collection. The bathroom features a glass-surround shower with both waterfall and handheld shower heads, along with a spacious bathtub for unwinding after a day in the city.</p>
        <div class="room-ctas">
          <a href="https://www.edgewaterhotel.com/#/booking/step-1" class="btn btn-primary" target="_blank" rel="noopener">Check Availability</a>
          <a href={tourUrl} class="btn btn-outline" target="_blank" rel="noopener">Take a 360&deg; Tour</a>
        </div>
      </div>

      <div class="room-sidebar">
        <div class="azds-booking-container">
          <h3>Book This Suite</h3>
          <div id="azds-booking-widget"></div>
          <a href="https://www.edgewaterhotel.com/#/booking/step-1" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: var(--space-sm);" target="_blank" rel="noopener">Check Availability</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Amenities -->
  <section class="section section-cream">
    <div class="container">
      <span class="label">In Your Suite</span>
      <h2 style="margin-top: 0.5rem; margin-bottom: var(--space-md);">Special Touches</h2>
      <ul class="room-detail-amenities">
        {amenities.map((a: any) => <li>{a.name}</li>)}
      </ul>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: var(--space-md);">Take a Look Inside</h2>
    </div>
    <div class="gallery-strip">
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/01/Edgewater_Dockside_LgBalcony.jpg" alt="Balcony overlooking the water" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/01/nhh200-noble-house-edgewater-stay-beatles-5.jpg" alt="Beatles suite lounge" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/01/nhh200-noble-house-edgewater-stay-beatles-4.jpg" alt="Beatles-inspired bedroom" loading="lazy" />
      <img src="https://admin.edgewaterhotel.com/content/uploads/2026/01/nhh200-noble-house-edgewater-stay-beatles-2.jpg" alt="Beatles suite overview" loading="lazy" />
    </div>
  </section>

  <!-- Offers CTA -->
  <section class="cta-banner">
    <div class="hero-bg">
      <img src="https://admin.edgewaterhotel.com/content/uploads/2025/12/nhh200-noble-house-edgewater-offers3.jpg" alt="Lounge at The Edgewater" loading="lazy" />
    </div>
    <div class="hero-overlay"></div>
    <div class="container cta-banner-content">
      <h2>Offers & Packages</h2>
      <p>Add exclusive packages and special offers to your stay in the Emerald City.</p>
      <a href="#" class="btn btn-sand">View All Offers</a>
    </div>
  </section>

</Layout>

<style>
  .breadcrumb {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }
  .breadcrumb:hover { color: #fff; }

  .room-hero .room-meta span {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.3);
    color: #fff;
  }

  .room-content-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--space-xl);
    align-items: start;
  }

  .room-description .lead {
    font-size: 1.2rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .room-description p {
    color: var(--warm-gray);
    margin-bottom: var(--space-sm);
    line-height: 1.8;
  }

  .room-ctas {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .room-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-md));
  }

  @media (max-width: 900px) {
    .room-content-grid { grid-template-columns: 1fr; }
    .room-sidebar { position: static; }
  }
</style>
